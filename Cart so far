<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Paddle Header</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap');

        :root {
            --bg-color: #0F1A14;
            --img: #E9E0D8;
            --edit: #989386;
            --font-family: "DM Sans", system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            --button-radius: 6px;
            --button-color: #E9E0D8;
            --button-hover-bg: #E9E0D8;
            --button-hover-color: #E9E0D8;

            --transition-fast: 220ms cubic-bezier(.25, .8, .25, 1);
            --transition-smooth: 360ms cubic-bezier(.22, .9, .28, 1);
            --fs-button: clamp(13px, 1vh + 1vh, 20px);
            --pbtn-size: clamp(36px, 3.6vh, 56px);
            --icon-size: calc(var(--pbtn-size) * 0.64);
            --icon-stroke: 2.4;
            --fs-brand: clamp(18px, 2.4vh + 0.8vh, 36px);
            --fs-tooltip: clamp(12px, 1vh + 0.6vh, 16px);

            --site-cart-width: 30%;
            --site-cart-gap-left: 2vh;
            /* gap between header right edge and cart left edge */
            --site-cart-gap-right: 0px;
            /* gap between cart right edge and viewport right edge */
            --site-cart-top: 0px;
            /* distance from viewport top to cart top */
            --site-cart-bottom: 0px;
            /* distance from viewport bottom to cart bottom */
            --site-cart-ease: cubic-bezier(.22, .9, .28, 1);
        }

        .special-header {
            width: 100%;
            padding: 1.6vh;
            background: var(--bg-color);
            color: #fff;
            font-family: var(--font-family);
            border-radius: 0.8vh;
            display: flex;
            align-items: stretch;
            box-sizing: border-box;
            gap: 1vh;
            position: relative;
            z-index: 2147483647;
        }

        .special-header-section {
            flex: 1;
            display: flex;
            align-items: center;
            box-sizing: border-box;
            overflow: hidden;
            padding: 0;
            gap: 0.8vh;
        }

        .special-header-section.left {
            justify-content: flex-start;
        }

        .special-header-section.center {
            justify-content: center;
        }

        .special-header-section.right {
            justify-content: flex-end;
        }

        .brand {
            line-height: 1;
            font-weight: 400;
            user-select: none;
            color: #ECF4EF;
            font-size: var(--fs-brand);
            text-decoration: none;
            /* remove default link underline when brand is an anchor */
            display: inline-block;
        }

        .brand:focus-visible {
            outline: none;
            box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.14);
            border-radius: 6px;
        }

        .p-button {
            --pad-v: 1vh;
            --pad-h: 1vh;
            padding: calc(var(--pad-v) - 0.2vh) calc(var(--pad-h) + 0.2vh);
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--button-radius);
            cursor: pointer;
            box-sizing: border-box;
            color: var(--button-color);
            background: transparent;
            position: relative;
            overflow: hidden;
            transition: background var(--transition-fast), color var(--transition-fast);
            font-family: inherit;
            line-height: 1;
            user-select: none;
        }

        .p-button:hover,
        .p-button:focus,
        .p-button[aria-expanded="true"] {
            color: var(--button-hover-color);
            background: var(--button-hover-bg);
            outline: none;
        }

        .p-button:focus-visible {
            box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.14);
        }

        .p-button-text {
            padding: 0;
            border-radius: 3px;
            display: inline-block;
            line-height: 1;
            white-space: nowrap;
            transform: translateX(0);
            transition: transform var(--transition-smooth);
            will-change: transform;
            font-weight: 500;
            font-size: var(--fs-button);
            pointer-events: none;
        }

        .p-button .p-button-icon {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(160%, -50%);
            opacity: 0;
            pointer-events: none;
            transition: transform var(--transition-smooth), opacity var(--transition-smooth);
            will-change: transform, opacity;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .p-button .p-button-icon-inner {
            display: inline-block;
            transform: translateY(0);
        }

        .p-button .p-button-icon svg {
            display: block;
            width: calc(var(--fs-button) * 0.9);
            height: calc(var(--fs-button) * 0.9);
        }

        @keyframes bob {
            0% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-10%);
            }

            100% {
                transform: translateY(0);
            }
        }

        .p-button:hover .p-button-text,
        .p-button:focus .p-button-text {
            transform: translateX(-140%);
        }

        .p-button:hover .p-button-icon,
        .p-button:focus .p-button-icon {
            opacity: 1;
            transform: translate(-50%, -50%);
        }

        .p-button:hover .p-button-icon-inner,
        .p-button:focus .p-button-icon-inner {
            animation: bob 800ms ease-in-out 120ms infinite;
        }

        .special-header-section.right>.p-button+.p-button {
            margin-left: 0.8vh;
        }

        .p-icon-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--button-radius);
            cursor: pointer;
            margin-left: 0.8vh;
            box-sizing: border-box;
            color: var(--button-color);
            background: transparent;
            position: relative;
            overflow: visible;
            transition: background var(--transition-fast), color var(--transition-fast);
            font-family: inherit;
            line-height: 1;
            user-select: none;

            height: var(--pbtn-size);
            width: var(--pbtn-size);
            padding: 0;
            min-width: 0;
            flex: 0 0 auto;
        }

        .p-icon-button:hover,
        .p-icon-button:focus,
        .p-icon-button[aria-expanded="true"] {
            color: var(--button-hover-color);
            background: var(--button-hover-bg);
            outline: none;
        }

        .p-icon-button:focus-visible {
            box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.14);
        }

        .p-icon-button .p-button-icon {
            position: absolute;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 1;
            pointer-events: none;
            transition: transform var(--transition-smooth), opacity var(--transition-smooth);
        }

        .p-icon-button .p-button-icon-inner {
            display: inline-block;
            transform: translateY(0);
        }

        .p-icon-button .p-button-icon svg {
            width: var(--icon-size);
            height: var(--icon-size);
            display: block;
            vertical-align: middle;
            stroke: currentColor;
            fill: none;
            stroke-width: var(--icon-stroke);
        }

        .p-icon-button:hover .p-button-icon-inner,
        .p-icon-button:focus .p-button-icon-inner {
            animation: bob 800ms ease-in-out 120ms infinite;
        }

        .TopbarTooltip {
            position: fixed;
            z-index: 9999;
            pointer-events: none;
            display: inline-block;
            background: rgba(10, 18, 14, 0.95);
            color: #ECF4EF;
            font-family: var(--font-family);
            font-size: var(--fs-tooltip);
            padding: 0.45vh 0.8vh;
            border-radius: 0.8vh;
            box-shadow: 0 0.6vh 1.0vh rgba(0, 0, 0, 0.45);
            transform-origin: left top;
            transform: translate3d(0, 0, 0) scale(0.96);
            transition: opacity 120ms ease, transform 120ms ease;
            opacity: 0;
            white-space: nowrap;
            will-change: transform, opacity, left, top;
        }

        .TopbarTooltip.visible {
            opacity: 1;
            transform: translate3d(0, 0, 0) scale(1);
        }

        /* ── Cart backdrop ──────────────────────────────────────────────────── */
        #site-cart-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.45);
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
            z-index: 2147483646;
            /* one below the cart drawer */
            opacity: 0;
            pointer-events: none;
            transition: opacity 360ms var(--site-cart-ease);
        }

        #site-cart-backdrop.open {
            opacity: 1;
            pointer-events: auto;
        }

        /* ── Cart panel ─────────────────────────────────────────────────────── */

        /* Header shifts left when cart is open, leaving a gap equal to --site-cart-gap-left */
        .special-header {
            transition: margin-right 360ms var(--site-cart-ease),
                width 360ms var(--site-cart-ease);
        }

        .special-header.cart-is-open {
            width: calc(100% - var(--site-cart-width) - var(--site-cart-gap-right) - var(--site-cart-gap-left));
            margin-right: calc(var(--site-cart-width) + var(--site-cart-gap-right) + var(--site-cart-gap-left));
        }

        /* Full-height drawer anchored to the right edge of the viewport */
        #site-cart-drawer {
            position: fixed;
            top: var(--site-cart-top);
            right: var(--site-cart-gap-right);
            bottom: var(--site-cart-bottom);
            width: var(--site-cart-width);
            background: var(--img);
            color: #2C4C3B;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            border-radius: 0.8vh 0 0 0.8vh;
            box-shadow: -4px 0 24px rgba(0, 0, 0, 0.12);
            z-index: 2147483647;
            will-change: transform, opacity;
            transform: translate3d(calc(100% + var(--site-cart-gap-right) + 4px), 0, 0);
            opacity: 0;
            transition: transform 360ms var(--site-cart-ease),
                opacity 260ms var(--site-cart-ease);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            font-family: var(--font-family);
        }

        #site-cart-drawer.open {
            transform: translate3d(0, 0, 0);
            opacity: 1;
        }

        /* Cart inner sections */
        #site-cart-drawer .cart-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.2rem 1.2rem 1rem;
            border-bottom: 1px solid rgba(44, 76, 59, 0.08);
            font-weight: 600;
            font-size: clamp(15px, 1.6vh, 20px);
            flex-shrink: 0;
        }

        #site-cart-drawer .cart-body {
            flex: 1 1 auto;
            overflow-y: auto;
            padding: 1.2rem;
            background: var(--img);
            -webkit-overflow-scrolling: touch;
        }

        #site-cart-drawer .cart-footer {
            flex-shrink: 0;
            padding: 1rem 1.2rem;
            border-top: 1px solid rgba(44, 76, 59, 0.08);
            background: var(--img);
        }

        #site-cart-drawer .cart-empty {
            color: rgba(44, 76, 59, 0.55);
            font-size: clamp(13px, 1.4vh, 16px);
            margin-top: 0.4rem;
        }

        /* Close button inside the cart */
        #site-cart-drawer .cart-close-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: var(--pbtn-size);
            height: var(--pbtn-size);
            border: none;
            background: transparent;
            color: #2C4C3B;
            border-radius: var(--button-radius);
            cursor: pointer;
            flex-shrink: 0;
            transition: background var(--transition-fast);
        }

        #site-cart-drawer .cart-close-btn:hover,
        #site-cart-drawer .cart-close-btn:focus {
            background: rgba(44, 76, 59, 0.08);
            outline: none;
        }

        #site-cart-drawer .cart-close-btn:focus-visible {
            box-shadow: 0 0 0 3px rgba(44, 76, 59, 0.18);
        }

        #site-cart-drawer .cart-close-btn svg {
            width: var(--icon-size);
            height: var(--icon-size);
            stroke: currentColor;
            fill: none;
            stroke-width: var(--icon-stroke);
            display: block;
        }

        /* Checkout button */
        #site-cart-drawer .cart-checkout-btn {
            width: 100%;
            padding: 0.9rem 1rem;
            border-radius: var(--button-radius);
            background: #1E3428;
            color: #ECF4EF;
            border: none;
            cursor: pointer;
            font-family: var(--font-family);
            font-size: clamp(13px, 1.4vh, 16px);
            font-weight: 500;
            transition: background var(--transition-fast);
        }

        #site-cart-drawer .cart-checkout-btn:hover {
            background: #2C4C3B;
        }

        .cart-item {
            background: var(--edit);
            width: 100%;
            height: 14vh;
            border-radius: 1vh;
            position: relative;
            display: flex;
            flex-direction: column;
        }

        .cart-item-delete {
            position: absolute;
            top: 0.7vh;
            right: 0.7vh;
            background: none;
            cursor: pointer;
            padding: 0.4vh;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.75;
            transition: opacity var(--transition-fast);
            user-select: none;
        }

        .cart-item-delete:hover {
            opacity: 1;
        }

        .cart-item-thumbnail {
            flex: 1;
            min-height: 0;
            border-radius: 0.5vh 0.5vh 0 0;
        }

        .cart-item-info {
            padding: 0 1rem 0.8rem;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 0.15rem;
        }

        .cart-item-design {
            font-weight: 300;
            font-size: clamp(12px, 1.4vh, 16px);
        }

        .cart-item-title {
            font-weight: 600;
            font-size: clamp(15px, 2vh, 20px);
        }

    </style>
</head>

<body>
    <div class="special-header cart-is-open" role="banner">
