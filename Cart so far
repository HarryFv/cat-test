    <script>
        (function() {
            const pButtons = document.querySelectorAll('.p-button, .p-icon-button');

            function activate(el) {
                const action = el.getAttribute('data-action') || null;
                el.dispatchEvent(new CustomEvent('pbutton:activate', {
                    detail: {
                        action
                    },
                    bubbles: true
                }));
                el.setAttribute('aria-pressed', 'true');
                setTimeout(() => el.removeAttribute('aria-pressed'), 150);
            }

            pButtons.forEach(el => {
                el.addEventListener('click', () => activate(el));
                el.addEventListener('keydown', (ev) => {
                    if (ev.key === 'Enter' || ev.key === ' ' || ev.key === 'Spacebar') {
                        ev.preventDefault();
                        activate(el);
                    }
                });
            });

            document.querySelectorAll('.cart-item-delete').forEach(el => {
                el.addEventListener('keydown', (ev) => {
                    if (ev.key === 'Enter' || ev.key === ' ' || ev.key === 'Spacebar') {
                        ev.preventDefault();
                        el.click();
                    }
                });
            });
        })();
    </script>

    <script>
        (function() {
            const TOOLTIP_ID = 'header-shared-tooltip';
            let tooltip = document.getElementById(TOOLTIP_ID);

            if (!tooltip) {
                tooltip = document.createElement('div');
                tooltip.id = TOOLTIP_ID;
                tooltip.className = 'TopbarTooltip';
                tooltip.setAttribute('role', 'tooltip');
                tooltip.setAttribute('aria-hidden', 'true');
                document.body.appendChild(tooltip);
            }

            const MARGIN = 8;
            const CURSOR_OFFSET_X = 12;
            const CURSOR_OFFSET_Y = -12;

            function getTooltipText(btn) {
                return btn.getAttribute('data-tooltip') ||
                    btn.getAttribute('data-label') ||
                    (btn.querySelector && (btn.querySelector('.p-button-text') ? btn.querySelector('.p-button-text').textContent.trim() : '')) ||
                    btn.getAttribute('aria-label') || '';
            }

            function clampPosition(left, top, width, height) {
                const vw = Math.max(document.documentElement.clientWidth, window.innerWidth || 0);
                const vh = Math.max(document.documentElement.clientHeight, window.innerHeight || 0);
                let x = left,
                    y = top;
                if (x < MARGIN) x = MARGIN;
                if (y < MARGIN) y = MARGIN;
                if (x + width + MARGIN > vw) x = Math.max(MARGIN, vw - width - MARGIN);
                if (y + height + MARGIN > vh) y = Math.max(MARGIN, vh - height - MARGIN);
                return {
                    x,
                    y
                };
            }

            function positionAtPointer(clientX, clientY) {
                // place tooltip near the pointer; read its size, clamp to viewport
                tooltip.style.left = '0px';
                tooltip.style.top = '0px';
                const rect = tooltip.getBoundingClientRect();
                const desiredLeft = Math.round(clientX + CURSOR_OFFSET_X);
                const desiredTop = Math.round(clientY + CURSOR_OFFSET_Y - rect.height);
                const clamped = clampPosition(desiredLeft, desiredTop, rect.width, rect.height);
                tooltip.style.left = clamped.x + 'px';
                tooltip.style.top = clamped.y + 'px';
            }

            function positionAboveElement(el) {
                tooltip.style.left = '0px';
                tooltip.style.top = '0px';
                const rect = tooltip.getBoundingClientRect();
                const btnRect = el.getBoundingClientRect();
                const desiredLeft = Math.round(btnRect.left + (btnRect.width - rect.width) / 2);
                const desiredTop = Math.round(btnRect.top - rect.height - 8);
                const clamped = clampPosition(desiredLeft, desiredTop, rect.width, rect.height);
                tooltip.style.left = clamped.x + 'px';
                tooltip.style.top = clamped.y + 'px';
            }

            let currentTarget = null;
            // store most recent pointer coordinates so focus (from a pointer click) can reuse them
            let lastPointer = null;

            function showTooltip(text) {
                tooltip.textContent = text;
                tooltip.setAttribute('aria-hidden', 'false');
                tooltip.classList.add('visible');
            }

            function hideTooltip() {
                tooltip.setAttribute('aria-hidden', 'true');
                tooltip.classList.remove('visible');
                currentTarget = null;
                // don't zero lastPointer here — keep it until pointerleave to allow click -> focus to use it
            }

            function withinButton(pt, btn) {
                if (!pt) return false;
                const r = btn.getBoundingClientRect();
                return pt.x >= r.left && pt.x <= r.right && pt.y >= r.top && pt.y <= r.bottom;
            }

            function attachToButton(btn) {
                if (!btn || btn.dataset._ttInit === '1') return;
                btn.dataset._ttInit = '1';

                function onPointerEnter(e) {
                    const text = getTooltipText(btn);
                    if (!text) return;
                    lastPointer = {
                        x: e.clientX,
                        y: e.clientY
                    };
                    currentTarget = btn;
                    showTooltip(text);
                    positionAtPointer(e.clientX, e.clientY);
                }

                function onPointerMove(e) {
                    // update last pointer coordinates so subsequent focus (from click) can reuse them
                    lastPointer = {
                        x: e.clientX,
                        y: e.clientY
                    };
                    if (currentTarget !== btn) return;
                    positionAtPointer(e.clientX, e.clientY);
                }

                function onPointerLeave() {
                    hideTooltip();
                    lastPointer = null;
                }

                function onFocus() {
                    const text = getTooltipText(btn);
                    if (!text) return;
                    currentTarget = btn;
                    showTooltip(text);
                    // If the element was focused via a pointer (mouse) and we have recent pointer coords
                    // prefer positioning at the pointer so the tooltip continues to follow the mouse.
                    // Otherwise (keyboard focus), position above the element.
                    if (lastPointer && withinButton(lastPointer, btn)) {
                        positionAtPointer(lastPointer.x, lastPointer.y);
                    } else {
                        requestAnimationFrame(() => positionAboveElement(btn));
                    }
                }

                function onBlur() {
                    hideTooltip();
                }

                btn.addEventListener('pointerenter', onPointerEnter, {
                    passive: true
                });
                btn.addEventListener('pointermove', onPointerMove, {
                    passive: true
                });
                btn.addEventListener('pointerleave', onPointerLeave, {
                    passive: true
                });
                btn.addEventListener('focus', onFocus, {
                    passive: true
                });
                btn.addEventListener('blur', onBlur, {
                    passive: true
                });
            }

            Array.from(document.querySelectorAll('.p-button, .p-icon-button')).forEach(attachToButton);

            const observer = new MutationObserver(function(mutations) {
                for (const m of mutations) {
                    for (const node of m.addedNodes) {
                        if (!(node instanceof HTMLElement)) continue;
                        if (node.matches && (node.matches('.p-button') || node.matches('.p-icon-button'))) attachToButton(node);
                        node.querySelectorAll && node.querySelectorAll('.p-button, .p-icon-button').forEach(attachToButton);
                    }
                }
            });
            observer.observe(document.body, {
                childList: true,
                subtree: true
            });

            window.addEventListener('scroll', function() {
                if (tooltip.classList.contains('visible') && currentTarget) requestAnimationFrame(function() {
                    // if the tooltip is following the pointer, keep it where the pointer is (no pointer coords during scroll).
                    // For simplicity reposition above the element on scroll if visible and focused.
                    positionAboveElement(currentTarget);
                });
            }, {
                passive: true
            });

            document.removeEventListener && document.removeEventListener('pbutton:activate', null);
            document.addEventListener('pbutton:activate', (e) => {
                try {
                    if (!e || !e.detail || e.detail.action !== 'products') return;

                    // Updated to use your shop page
                    const url = 'https://jvhjljda.elementor.cloud/shop/';

                    window.location.assign(url);

                } catch (err) {
                    try {
                        window.location.href = 'https://jvhjljda.elementor.cloud/shop/';
                    } catch (_) {}
                }
            });
            window.addEventListener('resize', function() {
                hideTooltip();
            }, {
                passive: true
            });
            window.addEventListener('blur', function() {
                hideTooltip();
            }, {
                passive: true
            });

            window._headerTooltip = {
                el: tooltip,
                showFor: function(btnOrText) {
                    if (typeof btnOrText === 'string') {
                        showTooltip(btnOrText);
                        // center in viewport when explicit string is provided (external callers)
                        positionAtPointer(window.innerWidth / 2, window.innerHeight / 2);
                    } else if (btnOrText instanceof HTMLElement) {
                        const t = getTooltipText(btnOrText);
                        showTooltip(t);
                        // prefer pointer coordinates if available, otherwise position above the element
                        if (lastPointer && withinButton(lastPointer, btnOrText)) {
                            positionAtPointer(lastPointer.x, lastPointer.y);
                        } else {
                            positionAboveElement(btnOrText);
                        }
                    }
                },
                hide: hideTooltip
            };
        })();
    </script>

    <!-- ── Cart open / close logic ──────────────────────────────────────── -->
    <script>
        (function() {
            var header = document.querySelector('.special-header');
            var drawer = document.getElementById('site-cart-drawer');
            var backdrop = document.getElementById('site-cart-backdrop');
            var closeBtn = drawer && drawer.querySelector('[data-action="close-cart"]');
            var focusableSelector = 'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])';
            var lastFocused = null;

            function isOpen() {
                return drawer && drawer.classList.contains('open');
            }

            function openCart(triggerBtn) {
                if (!drawer || isOpen()) return;
                lastFocused = document.activeElement;
                drawer.classList.add('open');
                drawer.setAttribute('aria-hidden', 'false');
                if (backdrop) {
                    backdrop.classList.add('open');
                    backdrop.setAttribute('aria-hidden', 'false');
                }
                if (header) header.classList.add('cart-is-open');
                var first = drawer.querySelector(focusableSelector);
                (first || drawer).focus();
            }

            function closeCart() {
                if (!drawer || !isOpen()) return;
                drawer.classList.remove('open');
                drawer.setAttribute('aria-hidden', 'true');
                if (backdrop) {
                    backdrop.classList.remove('open');
                    backdrop.setAttribute('aria-hidden', 'true');
                }
                if (header) header.classList.remove('cart-is-open');
                if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
                lastFocused = null;
            }

            // focus trap + ESC
            function isVisible(el) {
                return !!(el.offsetWidth || el.offsetHeight || el.getClientRects().length);
            }

            document.addEventListener('keydown', function(e) {
                if (!isOpen()) return;
                if (e.key === 'Escape') {
                    e.preventDefault();
                    closeCart();
                    return;
                }
                if (e.key === 'Tab') {
                    var focusables = Array.from(drawer.querySelectorAll(focusableSelector)).filter(isVisible);
                    if (!focusables.length) {
                        e.preventDefault();
                        return;
                    }
                    var first = focusables[0],
                        last = focusables[focusables.length - 1];
                    if (e.shiftKey && document.activeElement === first) {
                        e.preventDefault();
                        last.focus();
                    } else if (!e.shiftKey && document.activeElement === last) {
                        e.preventDefault();
                        first.focus();
                    }
                }
            });

            // open on cart button click or pbutton:activate
            document.addEventListener('click', function(e) {
                var btn = e.target.closest && e.target.closest('[data-action="cart"]');
                if (btn) {
                    e.preventDefault();
                    openCart(btn);
                }
            });
            document.addEventListener('pbutton:activate', function(e) {
                try {
                    if (e && e.detail && e.detail.action === 'cart') openCart(e.target || null);
                } catch (_) {}
            });

            if (closeBtn) closeBtn.addEventListener('click', closeCart);
            if (backdrop) backdrop.addEventListener('click', closeCart);

            // public API
            window._siteCart = window._siteCart || {};
            window._siteCart.open = openCart;
            window._siteCart.close = closeCart;
            window._siteCart.el = drawer;
            window._siteCart.contentEl = document.getElementById('site-cart-content');
            window._siteCart.setContent = function(html) {
                if (window._siteCart.contentEl) window._siteCart.contentEl.innerHTML = html;
            };
        })();
    </script>
